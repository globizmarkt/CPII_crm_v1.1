rules_version = '2';

// ============================================================================
// FIRESTORE SECURITY RULES — CPII_crm_v1.1
// ============================================================================
// tenant_id canónico : cpii_v1.1
// Doctrina           : ATOM-07 (default-deny) | ATOM-02 (tenant isolation)
//                      ATOM-06 (_slug_reservations) | ATOM-08 (events append-only)
// Fuente             : 05.2_mapa_arqueologico_firebase_crm.md (REBORN-02.2)
//                      FIRESTORE_SECURITY_RULES_TEMPLATE.md (04_ARCHIVE)
// Principio          : Aislamiento Lógico Perimetral — JWT como muro criptográfico
// Timestamp          : 2026-05-19
// Versión            : 2.0.0 — REBORN-02.2
// ============================================================================
// CHANGELOG v2.0.0:
//   - ADD: colección contacts + subcolección events (append-only, FRT-06 fix)
//   - ADD: colección _slug_reservations (ATOM-06)
//   - UPD: isStaff() → roles canónicos: admin, compliance, manager, agent
//   - UPD: belongsToTenant() → cpii_v1.1 hardcoded (ATOM-02 estricto)
//   - ADD: isAdmin() — operaciones destructivas y configuración
//   - ADD: isCompliance() — acceso a compliance_alerts + datos KYC
//   - ADD: isDocumentOwner() — contacto asignado al agente logueado
// ============================================================================
// DESPLIEGUE: Director ejecuta `firebase deploy --only firestore:rules` (DIR-01)
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNCIONES DE BLINDAJE ──────────────────────────────────────────────

    // Verifica que el token JWT del usuario pertenece al tenant canónico cpii_v1.1.
    // Anti-spoofing: impide acceso a usuarios de otros tenants aunque estén auth.
    // Mandato REBORN-02.2: request.auth.token.tenant_id == 'cpii_v1.1' (ATOM-02 estricto).
    function belongsToTenant() {
      return request.auth != null &&
             request.auth.token.tenant_id == 'cpii_v1.1';
    }

    // Verifica que el documento a crear lleva el tenant_id correcto.
    // "Marca de Nacimiento" doctrinal — obligatorio en todo addDoc/setDoc.
    // Doble check: token.tenant_id == resource.tenant_id == 'cpii_v1.1'.
    function isCreateValid() {
      return request.auth != null &&
             request.resource.data.tenant_id == 'cpii_v1.1' &&
             request.resource.data.tenant_id == request.auth.token.tenant_id;
    }

    // Rol Staff canónico — acceso CRM completo dentro del tenant.
    // Roles autorizados: admin, compliance, manager, agent (NO investor).
    // Fuente: 05.2_mapa_arqueologico §2.2 + mandato REBORN-02.2.
    function isStaff() {
      return request.auth != null &&
             request.auth.token.tenant_id == 'cpii_v1.1' &&
             request.auth.token.role in ['admin', 'compliance', 'manager', 'agent'];
    }

    // Rol Admin exclusivo — operaciones de configuración y borrado.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.tenant_id == 'cpii_v1.1' &&
             request.auth.token.role == 'admin';
    }

    // Rol Compliance — acceso a alertas KYC/AML y datos sensibles.
    // Incluye admin (jerarquía de permisos acumulativa).
    function isCompliance() {
      return request.auth != null &&
             request.auth.token.tenant_id == 'cpii_v1.1' &&
             request.auth.token.role in ['admin', 'compliance'];
    }

    // El usuario autenticado es el agente asignado al documento (ownerId).
    // Usado para contacts: permite que el agente lea/modifique sus propios leads.
    function isDocumentOwner() {
      return request.auth != null &&
             resource.data.ownerId == request.auth.uid;
    }


    // ── COLECCIÓN: contacts ───────────────────────────────────────────────
    // Ficha única del inversor/lead. Filtro raíz: tenant_id (ATOM-02).
    // Staff completo puede leer y escribir dentro del tenant.
    // El agente asignado (ownerId) puede leer su propio contacto.
    // Borrado físico PROHIBIDO — solo soft-delete (isActive=false).
    match /contacts/{contactId} {
      allow read:   if belongsToTenant() && (isStaff() || isDocumentOwner());
      allow create: if isCreateValid()   && isStaff();
      allow update: if belongsToTenant() && isStaff();
      allow delete: if false; // Soft-delete ÚNICAMENTE (isActive=false) — ATOM-05

      // ── SUBCOLECCIÓN: events (append-only — ATOM-08) ──────────────────
      // Historial inmutable de transiciones de pipeline y touchpoints.
      // Solo staff puede crear. NADIE puede editar ni borrar.
      match /events/{eventId} {
        allow read:           if belongsToTenant() && isStaff();
        allow create:         if isCreateValid()   && isStaff();
        allow update, delete: if false; // Inmutable — append-only (ATOM-08)
      }
    }

    // ── COLECCIÓN: users ──────────────────────────────────────────────────
    // Perfiles de usuario (agentes, compliance, admins) + Custom Claims.
    // Cada usuario lee/actualiza su propio perfil dentro del tenant.
    // Admin puede leer cualquier perfil del tenant.
    match /users/{uid} {
      allow read:   if belongsToTenant() && (request.auth.uid == uid || isAdmin());
      allow update: if belongsToTenant() &&  request.auth.uid == uid;
      allow create: if isCreateValid();
      allow delete: if false;
    }

    // ── COLECCIÓN: _slug_reservations ─────────────────────────────────────
    // Centinela de unicidad de slugs (ATOM-06).
    // Opera exclusivamente vía Firebase Admin SDK (Cloud Functions).
    // Admin SDK bypasses rules → las reglas bloquean acceso desde cliente.
    match /_slug_reservations/{slug} {
      allow read, write: if false; // Admin SDK only — bypasses rules
    }

    // ── COLECCIÓN: leads ──────────────────────────────────────────────────
    // Legacy: documentos de captación creados por access-form.html (CPII v1.0/1.1).
    // Staff puede leer, actualizar y eliminar. Creación protegida por tenant_id.
    match /leads/{leadId} {
      allow read, update, delete: if belongsToTenant() && isStaff();
      allow create:               if isCreateValid()   && isStaff();
    }

    // ── COLECCIÓN: staff ──────────────────────────────────────────────────
    // Lista de agentes/gestores/compliance (metadatos + licencia AMI).
    // Todo staff puede leer sus propios registros y los del equipo.
    // Solo Admin puede crear o modificar registros de staff.
    match /staff/{staffId} {
      allow read:  if belongsToTenant() && isStaff();
      allow write: if belongsToTenant() && isAdmin();
    }

    // ── COLECCIÓN: compliance_alerts ──────────────────────────────────────
    // Alertas KYC/AML/PEP activas e históricas.
    // Solo Compliance (admin + compliance) puede leer y operar.
    match /compliance_alerts/{alertId} {
      allow read:   if belongsToTenant() && isCompliance();
      allow create: if isCreateValid()   && isCompliance();
      allow update: if belongsToTenant() && isCompliance();
      allow delete: if false; // Alertas inmutables — solo se marcan resolved
    }

    // ── COLECCIÓN: audit_log ──────────────────────────────────────────────
    // Bitácora append-only de eventos críticos del sistema.
    // Solo Compliance puede leer. Solo sistema (Admin SDK) puede escribir.
    match /audit_log/{eventId} {
      allow read:           if belongsToTenant() && isCompliance();
      allow create:         if false; // Admin SDK only — sistema escribe
      allow update, delete: if false; // Append-only absoluto
    }

    // ── COLECCIÓN: public_content ─────────────────────────────────────────
    // Contenido global sin restricción de tenant (textos públicos, etc.).
    match /public_content/{contentId} {
      allow read: if true;
    }

    // ── DEFAULT-DENY ──────────────────────────────────────────────────────
    // Cierre total: cualquier ruta no declarada explícitamente → denegada.
    // Doctrina ATOM-07: Zero Trust — lo no permitido es denegado.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
